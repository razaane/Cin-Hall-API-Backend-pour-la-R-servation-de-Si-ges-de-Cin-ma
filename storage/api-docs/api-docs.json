        "/api/payments/stripe": {
            "post": {
                "tags": [
                    "Payments"
                ],
                "summary": "Pay a reservation using Stripe",
                "operationId": "d95e2910a8ee48d33fd5df314f132b8c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "reservation_id",
                                    "payment_method_id"
                                ],
                                "properties": {
                                    "reservation_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "payment_method_id": {
                                        "type": "string",
                                        "example": "pm_card_visa"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Payment successful"
                    },
                    "400": {
                        "description": "Invalid request or reservation issue"
                    },
                    "500": {
                        "description": "Payment failed"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
